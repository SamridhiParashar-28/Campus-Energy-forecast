# ── Copy this file to .env and fill in your values ────────
# NEVER commit .env to git — add it to .gitignore

# ── Database ───────────────────────────────────────────────
# LOCAL (SQLite — no installation needed, just a file)
DATABASE_URL=sqlite:///./wattwise.db

# PRODUCTION (uncomment when deploying, comment the SQLite line above)
# DATABASE_URL=postgresql://wattwise_user:yourpassword@localhost:5432/wattwise_db

# ── JWT ────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace_this_with_a_64_char_random_hex_string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# ── App ────────────────────────────────────────────────────
APP_ENV=development
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# ── First admin account (used by seed.py) ─────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_strong_password
