# WattWise – Environment Variables
# Copy this file to .env and fill in values

# JWT secret — change this to a long random string in production
JWT_SECRET=wattwise-change-this-secret-in-production

# Server port
PORT=5000

# Path to SQLite database file (relative to server.js)
DB_PATH=./data/wattwise.db

# Path to CSV dataset for initial seed
CSV_PATH=./dataset.csv
